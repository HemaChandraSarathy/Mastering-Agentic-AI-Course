# Copy to .env and fill in. NEVER commit .env.

# --- Nebius Token Factory (embeddings; OpenAI-compatible API) ---
# Course requirement: at least one model call must go through Nebius.
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1
# Pick a <=1024-dim embedding model so the pgvector HNSW index works directly
# (pgvector index limit = 2000 dims). bge-en-icl is 4096 dims and would need
# halfvec — avoid for simplicity. Confirm the exact model name in your Nebius console.
NEBIUS_EMBED_MODEL=BAAI/bge-large-en-v1.5    # 1024-dim; change to whatever Nebius offers
NEBIUS_EMBED_DIM=1024                         # MUST match the model AND the vector() column in db/0001_rag_tables.sql

# --- Anthropic (generation) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=                        # service role key (server-side only)

# --- LangSmith (optional tracing/eval) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=financial-doc-rag
# Optional: set true ONLY if you add a real LANGSMITH_API_KEY above (else you get 401 spam).
LANGSMITH_TRACING=false

# --- Local corpus path ---
CORPUS_DIR=./corpus
